# Mux credentials (required)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Mux signing keys (optional, for signed playback URLs)
MUX_SIGNING_KEY=
MUX_PRIVATE_KEY=

# AI provider keys (at least one required, depending on which provider you use)
# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
# ElevenLabs (https://elevenlabs.io/app/settings/api-keys)
# Required for translateAudio workflow
ELEVENLABS_API_KEY=

# S3-Compatible Storage (Required for translation workflows)
# AWS S3 Example
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# PostgreSQL connection string - Required to store/search the Mux catalog metadata
DATABASE_URL=